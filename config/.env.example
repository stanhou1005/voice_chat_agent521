# ============================================================
# Voice Chat Agent — 配置文件模板
# 使用方法: cp .env.example .env 然后编辑 .env 填入真实值
# 外挂目录: Docker Compose 会将此目录挂载到容器 /config
# ============================================================

# ── PostgreSQL 数据库 ──────────────────────────────────
PG_HOST=postgres
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=voice_chat

# ── DeepSeek API（LangGraph 智能体调用 LLM）────────────
LLM_MODEL_NAME=deepseek-v4-pro
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-deepseek-api-key-here

# ── 硅基流动 API（ASR 语音识别 + TTS 语音合成）────────
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key-here

# ── Tavily Search API（多 key 用逗号分隔，每次搜索随机选一个）──
TAVILY_API_KEY=tvly-key1,tvly-key2

# ── HTTP 代理（可选，留空则不使用）────────────────────
PROXY_URL=

# ── JWT 认证密钥（生产环境请改为随机长字符串）─────────
JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRE_HOURS=72

# ── 对外端口（如果 80/443 被占用可改）─────────────────
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=8443
